{
  "name": "admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "NODE_OPTIONS=--max-old-space-size=2048 next dev --turbopack -H 0.0.0.0 -p 5000",
    "emulators": "firebase emulators:start --import=./emulator-data --export-on-exit=./emulator-data",
    "dev": "pnpm run \"/^(dev:server|emulators)$/\"",
    "build": "next build",
    "start": "next start -p 5000",
    "lint": "next lint",
    "tc": "tsc --noEmit",
    "test": "vitest run",
    "prebuild": "tsc --noEmit",
    "clean": "rm -rf .next .vercel",
    "cil": "rm -rf node_modules pnpm-lock.yaml && pnpm install",
    "typecheck": "tsc -b && rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.138",
    "@aws-sdk/client-s3": "^3.1040.0",
    "@aws-sdk/s3-request-presigner": "^3.1040.0",
    "@base-ui/react": "^1.4.1",
    "@devicon/react": "^0.0.3",
    "@floating-ui/dom": "^1.7.6",
    "@open-notion/editor": "^1.8.1",
    "@tabsircg/schemas": "workspace:*",
    "@tailwindcss/postcss": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "emoji-regex": "^10.6.0",
    "firebase-admin": "^12.7.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1",
    "sharp": "^0.33.5",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "ua-parser-js": "^2.0.9",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/react": "18.3.12",
    "@types/react-dom": "^18.3.7",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "prettier": "^3.8.3",
    "shadcn": "^4.6.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
